{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ES2024", "DOM"],
        "declaration": false,
        "emitDeclarationOnly": true,
        "allowJs": true,
        "outDir": "types",
        "skipLibCheck": true
    },
    "include": [
        "packages/**/*",
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}