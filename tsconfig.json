{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ES2024", "DOM"],
        "declaration": true,
        "emitDeclarationOnly": true,
        "allowJs": true,
        "checkJs": false,
        "outDir": "types",
        "skipLibCheck": true,
    },
    "include": [
        "packages/**/*",
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/dist/**",
        "**/*.test.js"
    ]
}
