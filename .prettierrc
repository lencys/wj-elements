{
  "arrowParens": "always",
  "bracketSpacing": true,
  "embeddedLanguageFormatting": "off",
  "htmlWhitespaceSensitivity": "css",
  "insertPragma": false,
  "overrides":
    [
      { "files": "*.json", "options": { "singleQuote": false } },
      { "files": ".prettierrc", "options": { "singleQuote": false } },
    ],
  "printWidth": 120,
  "proseWrap": "preserve",
  "requirePragma": false,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false,
  "quoteProps": "as-needed",
}
